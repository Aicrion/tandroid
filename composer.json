{
    "name": "aicrion/tandroid",
    "description": "Android-inspired OS-like framework for building Telegram bots in PHP 8.5+",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "symfony/dependency-injection": "^7.1",
        "symfony/event-dispatcher": "^7.1",
        "symfony/cache": "^7.1",
        "symfony/config": "^7.1",
        "symfony/yaml": "^7.1",
        "symfony/messenger": "^7.1",
        "symfony/http-client": "^7.1",
        "doctrine/orm": "^3.2",
        "doctrine/dbal": "^4.0",
        "doctrine/migrations": "^3.8",
        "predis/predis": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Aicrion\\Tandroid\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload-dev": {
        "psr-4": {
            "Aicrion\\Tandroid\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    }
}
